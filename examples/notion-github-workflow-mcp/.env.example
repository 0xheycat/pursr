# Optional: if omitted, the MCP Bearer token sent by Notion is used as the GitHub token.
GITHUB_TOKEN=github_pat_xxx

# Optional: if set, Notion must send this token as the MCP Bearer token.
# If omitted, any Bearer token is accepted and treated as the GitHub token.
MCP_BEARER_TOKEN=notion_connection_secret

PORT=33418
HOST=0.0.0.0
